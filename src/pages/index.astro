---
import Layout from '../layouts/Layout.astro';
---

<Layout title="酸溜溜 - 个人作品集">

<!-- HERO -->
<section class="hero">
	<div class="hero-bg">
		<div class="orb orb1"></div>
		<div class="orb orb2"></div>
		<div class="grid-bg"></div>
	</div>
	<div class="container hero-content">
		<div class="badge">
			<span class="badge-dot"></span>
			欢迎来到我的世界
		</div>
		<h1 class="hero-title">
			你好，我是<br />
			<span class="gradient-text">酸溜溜</span>
		</h1>
		<p class="hero-sub">
			我是<span id="typing"></span>
		</p>
		<p class="hero-desc">
			热爱创造，痴迷于把想法变成现实。<br />
			在这里，你可以看到我做过的一些有意思的项目。
		</p>
		<div class="hero-links">
			<a href="#projects" class="btn btn-primary">
				<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3h7v7H3zM14 3h7v7h-7zM14 14h7v7h-7zM3 14h7v7H3z"/></svg>
				看看作品
			</a>
			<a href="#contact" class="btn btn-ghost">联系我</a>
		</div>
		<div class="hero-stats">
			<div class="stat">
				<strong>3+</strong>
				<span>年折腾经验</span>
			</div>
			<div class="stat-div"></div>
			<div class="stat">
				<strong>10+</strong>
				<span>完成项目</span>
			</div>
			<div class="stat-div"></div>
			<div class="stat">
				<strong>5+</strong>
				<span>技术栈</span>
			</div>
		</div>
	</div>
</section>

<!-- ABOUT -->
<section id="about" class="about">
	<div class="container">
		<div class="section-label">关于我</div>
		<h2 class="section-title">我是谁？</h2>
		<div class="about-grid">
			<div class="about-card">
				<div class="about-icon">&#x1F3AF;</div>
				<h3>目标驱动</h3>
				<p>做每一件事都带着明确的目标，追求把东西做到自己能力范围内的最好。</p>
			</div>
			<div class="about-card">
				<div class="about-icon">&#x1F527;</div>
				<h3>技术栈</h3>
				<p>Node.js · Python · Vue · React · Linux · Docker</p>
			</div>
			<div class="about-card">
				<div class="about-icon">&#x1F680;</div>
				<h3>持续学习</h3>
				<p>技术更新很快，我始终保持学习状态，关注 AI、前沿领域。</p>
			</div>
		</div>
	</div>
</section>

<!-- PROJECTS -->
<section id="projects" class="projects">
	<div class="container">
		<div class="section-label">作品集</div>
		<h2 class="section-title">最近项目</h2>
		<div class="projects-grid">
			<div class="project-card">
				<div class="project-img p1">
					<div class="project-tag">AI</div>
				</div>
				<div class="project-body">
					<h3>AI 助手平台</h3>
					<p>基于大语言模型的智能助手，支持多轮对话、知识库问答、自动生成内容。</p>
					<div class="project-tags">
						<span>Vue3</span><span>Python</span><span>LLM</span><span>RAG</span>
					</div>
					<div class="project-links">
						<a href="#" class="proj-link">
							<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
							线上预览
						</a>
						<a href="#" class="proj-link">
							<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 00-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0020 4.77 5.07 5.07 0 0019.91 1S18.73.65 16 2.48a13.38 13.38 0 00-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 005 4.77a5.44 5.44 0 00-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 009 18.13V22"/></svg>
							源代码
						</a>
					</div>
				</div>
			</div>

			<div class="project-card">
				<div class="project-img p2">
					<div class="project-tag">效率工具</div>
				</div>
				<div class="project-body">
					<h3>自动化工作流平台</h3>
					<p>可视化拖拽搭建自动化流程，打通多个系统，自动完成数据同步、消息推送等任务。</p>
					<div class="project-tags">
						<span>Node.js</span><span>Vue3</span><span>Redis</span><span>Docker</span>
					</div>
					<div class="project-links">
						<a href="#" class="proj-link">
							<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
							线上预览
						</a>
						<a href="#" class="proj-link">
							<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 00-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0020 4.77 5.07 5.07 0 0019.91 1S18.73.65 16 2.48a13.38 13.38 0 00-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 005 4.77a5.44 5.44 0 00-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 009 18.13V22"/></svg>
							源代码
						</a>
					</div>
				</div>
			</div>

			<div class="project-card">
				<div class="project-img p3">
					<div class="project-tag">数据可视化</div>
				</div>
				<div class="project-body">
					<h3>数据大屏系统</h3>
					<p>实时数据可视化大屏，支持多数据源接入，自动刷新图表，适用于数据展示场景。</p>
					<div class="project-tags">
						<span>React</span><span>ECharts</span><span>Python</span><span>Kafka</span>
					</div>
					<div class="project-links">
						<a href="#" class="proj-link">
							<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
							线上预览
						</a>
						<a href="#" class="proj-link">
							<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 00-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0020 4.77 5.07 5.07 0 0019.91 1S18.73.65 16 2.48a13.38 13.38 0 00-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 005 4.77a5.44 5.44 0 00-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 009 18.13V22"/></svg>
							源代码
						</a>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<!-- CONTACT -->
<section id="contact" class="contact">
	<div class="container">
		<div class="contact-box">
			<div class="section-label">联系方式</div>
			<h2 class="section-title">想聊聊？</h2>
			<p class="contact-desc">无论是有合作想法，还是单纯想打个招呼，我都很乐意收到你的消息。</p>
			<div class="contact-links">
				<a href="mailto:your@email.com" class="contact-item">
					<span class="contact-icon">&#x2709;</span>
					<div>
						<strong>邮箱</strong>
						<span>your@email.com</span>
					</div>
				</a>
				<a href="#" class="contact-item">
					<span class="contact-icon">&#x1F4AC;</span>
					<div>
						<strong>微信</strong>
						<span>@yourname</span>
					</div>
				</a>
				<a href="https://github.com/liushuaikasumi" class="contact-item">
					<span class="contact-icon">&#x1F419;</span>
					<div>
						<strong>GitHub</strong>
						<span>github.com/liushuaikasumi</span>
